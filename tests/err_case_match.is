# EXPECT RUN: division by zero
# Case on result, match ok and error branches
@DivError error:
  @message String

@divide func(@a int, @b int) ok int else DivError:
  if b == 0:
    result = DivError(message=~"division by zero")
    return
  result = a / b

@r = divide(10, 0)
case r:
  of ok:
    *echo(->r)
  of DivError:
    *echo("division by zero")
