# Error handling with result

@DivError! error:
  @message String

@divide! func(@a int, @b int) ok int else DivError:
  if b == 0:
    result = DivError(message=~"division by zero")
    return
  result = a / b

# if/else
@r = divide(10, 3)
if not r:
  *echo("error")
  quit()
*echo(r.get())

# case
@r2 = divide(10, 0)
caseblock r2:
  of ok:
    *echo(r2.get())
  of DivError:
    *echo("caught error")
