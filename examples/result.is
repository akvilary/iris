# Error handling with ok / raise

@DivError! object:
  @message view[Str]  # TODO: change to Str when Str runtime is implemented

@divide! func(@a int, @b int) ok int else DivError:
  if b == 0:
    raise DivError(message="division by zero")
  result = a / b

# do...else
do @r = divide(10, 3) else:
  *echo("error")
  quit()
*echo(r.get())

# case
@r2 = divide(10, 0)
case r2:
  of ok:
    *echo(r2.get())
  of DivError:
    *echo("caught error")
