# String types demo

# str — from literal
@greeting = "hello"
*echo(greeting)

# String — owned, from ~"..."
@owned = ~"hello owned"
*echo(owned)

# String — from String() constructor
@built = String("hello built")
*echo(built)

# String — owned interpolation with ~"...{expr}..."
@name = "world"
@msg = ~"hello {name}!"
*echo(msg)
