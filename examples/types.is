# Types and enums in Iris

type Point*:
  @x: int
  @y: int

enum Color*:
  @red, @green, @blue

enum HttpMethod*:
  @get = "GET"
  @post = "POST"
  @put = "PUT"
  @delete = "DELETE"

# Create a point
let p = Point(10, 20)
echo(p.x)
echo(p.y)

# Use enum
let c = Color.red
echo(c)

# Case
case c:
  of Color.red:
    echo("Red!")
  of Color.green:
    echo("Green!")
  of Color.blue:
    echo("Blue!")
