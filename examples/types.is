# Types and enums in Iris

@Point+ object:
  @x+ int
  @y+ int

@Color+ enum:
  @red, @green, @blue

@HttpMethod+ enum:
  @get = "GET"
  @post = "POST"
  @put = "PUT"
  @delete = "DELETE"

# Create a point
@p = Point(10, 20)
echo(p.x)
echo(p.y)

# Use enum
@c = Color.red
echo(c)

# Case
case c:
  of Color.red:
    echo("Red!")
  of Color.green:
    echo("Green!")
  of Color.blue:
    echo("Blue!")
