# Unified ~ heap syntax demo

# ~"..." → Str (owned string)
@name = ~"Andrey"
*echo(name)

# ~[...] → Seq (dynamic sequence)
@nums mut = ~[10, 20, 30]
*echo(nums)

# ~{key: value} → HashTable
@scores = ~{~"alice": 100, ~"bob": 85}

# ~{values} → HashSet
@ids = ~{1, 2, 3, 4}

# ~{} → empty HashTable
@empty = ~{}

# ~Type(...) → Heap[Type]
@Point! object:
  @x! int
  @y! int

@p = Point(x=10, y=20)
*echo(p.x)

@hp = ~Point(x=30, y=40)
*echo(hp.x)
