# Concepts demo

@Printable concept:
  @toString func(@self) ok str

@User object:
  @name String
  @age int

# User satisfies Printable — has toString
@toString func(@self User) ok str:
  result = "user"

# Generic with concept constraint
@print func[T: Printable](@item T):
  *echo(toString(item))

@u = User(name=~"Alice", age=30)
print(u)
